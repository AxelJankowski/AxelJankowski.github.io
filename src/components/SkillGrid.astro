---
import { skills } from "../data/site";
---

<div class="bevel-in p-3">
  <div class="flex flex-wrap gap-3">
    {
      skills.map((skill) => (
        <div
          class="flex w-[76px] flex-col items-center gap-1 p-2 bevel-out"
          title={skill.name}
        >
          {"icon" in skill && skill.icon ? (
            <img
              src={skill.icon}
              alt={skill.name}
              class="h-10 w-10 shrink-0 object-contain"
              width="40"
              height="40"
              loading="lazy"
            />
          ) : (
            <span
              class="flex h-10 w-10 shrink-0 items-center justify-center bevel-in text-[10px] font-bold text-[#000080]"
            >
              {skill.name.slice(0, 2).toUpperCase()}
            </span>
          )}
          <span class="w-full text-center text-[10px] leading-tight">{skill.name}</span>
        </div>
      ))
    }
  </div>
</div>
